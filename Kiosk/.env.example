DEVICE_ID=DEVICE-01
API_BASE_URL=http://localhost:3000
API_TOKEN=

# Operator credentials — leave blank to use the self-registration wizard on first launch.
# After registration the app saves credentials automatically; you do not need to set these.
NODE_EMAIL=
NODE_PASSWORD=
POLL_INTERVAL_MS=5000
HEARTBEAT_INTERVAL_MS=30000
PRINTER_REFRESH_INTERVAL_MS=10000
DEFAULT_PRINTER=
SIMULATE_PRINT=true
FALLBACK_PRINTERS=Microsoft Print to PDF,Office Printer
MOCK_FILE_URL=https://example.com/sample.pdf
MOCK_OWNER=local-operator
MOCK_PRIORITY=normal
MOCK_FILE_PREFIX=sample
UNKNOWN_PRINTER_NAME=Unknown Printer
UNKNOWN_FILE_NAME=unknown-file
UNKNOWN_OWNER_NAME=server
HEARTBEAT_PAPER_LEVEL=HIGH
HEARTBEAT_INK_BLACK=80
STAGE_DOWNLOAD_MS=600
STAGE_SPOOL_MS=800
STAGE_PRINT_MS=1200
APP_VERSION=0.1.0

# WebSocket real-time job push (set true to enable after confirming backend is reachable)
WS_ENABLED=false

# How often to retry failed server callbacks (ms)
CALLBACK_RETRY_INTERVAL_MS=60000
