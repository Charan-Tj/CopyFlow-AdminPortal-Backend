PORT=3000

# Database Configuration
DATABASE_URL="postgresql://postgres.<project_ref>:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=5"
DIRECT_URL="postgresql://postgres.<project_ref>:[PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=copyflow

# Token signing secret
PRINT_TOKEN_SECRET="your_print_token_secret"

# Twilio credentials
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_PHONE_NUMBER="your_twilio_phone_number"

# Pi CUPS server IP and port
CUPS_SERVER_URL="http://192.168.1.100:631"
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=copyflow-jobs

# Redis and Queue configuration
REDIS_URL=redis://localhost:6379

# Comma-separated node codes that bypass kiosk heartbeat readiness checks in test/dev
# Example: TEST01,TEST02
EXEMPT_TEST_KIOSKS=TEST01

# WhatsApp Provider Selection
# available options: twilio, meta
WHATSAPP_PROVIDER=twilio

# PhonePe
# Webhook URL should point to backend endpoint (server-to-server)
PHONEPE_CALLBACK_URL=https://your-backend-domain.com/payment-webhook/phonepe
# Redirect URL should point to frontend page where users land after payment
PHONEPE_REDIRECT_URL=https://copy-flow.app/print-order
# Optional: source-specific redirects
PHONEPE_REDIRECT_WHATSAPP_URL=https://wa.me/919103423133
PHONEPE_REDIRECT_TELEGRAM_URL=https://t.me/CopyFlowDev_bot

# Cashfree redirect URLs
CASHFREE_REDIRECT_URL=https://copy-flow.app/print-order
CASHFREE_REDIRECT_WHATSAPP_URL=https://wa.me/919103423133
CASHFREE_REDIRECT_TELEGRAM_URL=https://t.me/CopyFlowDev_bot
