generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  UPLOADED
  PAID
  PRINTED
  FAILED
}

enum ColorMode {
  BW
  COLOR
}

model Kiosk {
  pi_id     String     @id
  secret    String
  location      String?
  paper_level   String   @default("HIGH") // HIGH, LOW, EMPTY
  last_heartbeat DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  jobs          PrintJob[]
}

model PrintJob {
  job_id         String     @id @default(uuid())
  kiosk_id       String
  page_count     Int
  color_mode     ColorMode
  status         JobStatus  @default(UPLOADED)
  payable_amount Decimal    @db.Decimal(10, 2)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  kiosk      Kiosk       @relation(fields: [kiosk_id], references: [pi_id])
  payment    Payment?
  printToken PrintToken?
}

model Payment {
  id                String   @id @default(uuid())
  job_id            String   @unique
  amount            Decimal  @db.Decimal(10, 2)
  currency          String   @default("INR")
  razorpay_order_id String   @unique
  status            String   // razorpay status (captured, created, etc)
  createdAt         DateTime @default(now())

  job PrintJob @relation(fields: [job_id], references: [job_id])
}

model PrintToken {
  id         String   @id @default(uuid())
  job_id     String   @unique
  token_hash String   @unique // Store hash to verify and prevent reuse if needed, or just existence
  expires_at DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  job PrintJob @relation(fields: [job_id], references: [job_id])
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String
  actor     String?  // 'kiosk:PI_123' or 'system' or 'admin'
  metadata  Json?
  timestamp DateTime @default(now())
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  role          String   @default("ADMIN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PricingConfig {
  id          String   @id @default(uuid())
  bw_price    Decimal  @db.Decimal(10, 2)
  color_price Decimal  @db.Decimal(10, 2)
  author      String   // Admin email or ID
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)
}
