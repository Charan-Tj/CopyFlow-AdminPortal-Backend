generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Kiosk {
  pi_id          String     @id
  secret         String
  location       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  last_heartbeat DateTime   @default(now())
  paper_level    String     @default("HIGH")
  node_id        String
  printer_list   Json?
  node           Node       @relation(fields: [node_id], references: [id])
  jobs           PrintJob[]
}

model PrintJob {
  job_id         String      @id @default(uuid())
  kiosk_id       String
  page_count     Int
  color_mode     ColorMode
  status         JobStatus   @default(UPLOADED)
  payable_amount Decimal     @db.Decimal(10, 2)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  claimed_at     DateTime?
  claimed_by     String?
  copies         Int         @default(1)
  file_checksum  String?
  file_url       String?
  node_id        String
  phone_number   String?
  sides          String      @default("single")
  payment        Payment?
  kiosk          Kiosk       @relation(fields: [kiosk_id], references: [pi_id])
  node           Node        @relation(fields: [node_id], references: [id])
  printToken     PrintToken?
}

model Payment {
  id                String   @id @default(uuid())
  job_id            String   @unique
  amount            Decimal  @db.Decimal(10, 2)
  currency          String   @default("INR")
  razorpay_order_id String   @unique
  status            String
  createdAt         DateTime @default(now())
  job               PrintJob @relation(fields: [job_id], references: [job_id])
}

model PrintToken {
  id         String   @id @default(uuid())
  job_id     String   @unique
  token_hash String   @unique
  expires_at DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())
  job        PrintJob @relation(fields: [job_id], references: [job_id])
}

model AuditLog {
  id        String   @id @default(uuid())
  event     String
  actor     String?
  metadata  Json?
  timestamp DateTime @default(now())
  node_id   String?
  node      Node?    @relation(fields: [node_id], references: [id])
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  role          String   @default("ADMIN")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PricingConfig {
  id          String   @id @default(uuid())
  bw_price    Decimal  @db.Decimal(10, 2)
  color_price Decimal  @db.Decimal(10, 2)
  author      String
  createdAt   DateTime @default(now())
  active      Boolean  @default(true)
  node_id     String?
  node        Node?    @relation(fields: [node_id], references: [id])
}

model Node {
  id                 String             @id @default(uuid())
  node_code          String             @unique
  name               String
  college            String
  city               String
  address            String?
  is_active          Boolean            @default(true)
  qr_token           String             @unique @default(uuid())
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  audit_logs         AuditLog[]
  kiosks             Kiosk[]
  credentials        NodeCredential[]
  pricing            PricingConfig[]
  jobs               PrintJob[]
  registration_codes RegistrationCode[]
}

model NodeCredential {
  id            String    @id @default(uuid())
  node_id       String
  email         String    @unique
  password_hash String
  role          String    @default("OPERATOR")
  last_login    DateTime?
  created_at    DateTime  @default(now())
  node          Node      @relation(fields: [node_id], references: [id])
}

model RegistrationCode {
  id         String    @id @default(uuid())
  node_id    String
  code       String    @unique
  created_by String
  used       Boolean   @default(false)
  used_at    DateTime?
  expires_at DateTime
  createdAt  DateTime  @default(now())
  node       Node      @relation(fields: [node_id], references: [id])
}

model ChatSession {
  id        String   @id @default(uuid())
  sender    String   @unique
  job_id    String?
  node_id   String?
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([job_id])
}

enum JobStatus {
  UPLOADED
  PAID
  PRINTED
  FAILED
}

enum ColorMode {
  BW
  COLOR
}
